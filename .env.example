# ================================
# App & Server
# ================================
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NODE_ENV=development
PAYLOAD_PUBLIC_FRONTEND_URL=http://localhost:3000

# ================================
# Secrets
# ================================
PAYLOAD_SECRET=your-payload-secret-here
PREVIEW_SECRET=your-preview-secret-here
CRON_SECRET=your-cron-secret-here

# ================================
# Database
# ================================
# PostgreSQL
# DATABASE_URI=postgresql://127.0.0.1:5432/your-database-name
# MongoDB
DATABASE_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/your-db-name?appName=Cluster0
DATABASE_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/your-db-name?appName=Cluster0

# ================================
# Admin
# ================================
ADMIN_EMAIL=admin@example.com
ADMIN_API_URL=http://localhost:3000/api

# ================================
# Payload URLs
# ================================
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3001

# ================================
# S3 / MinIO / R2 Storage
# ================================
ENABLE_S3=false
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_REGION=us-east-1
S3_ENDPOINT=https://your-s3-endpoint.example.com

# ================================
# Media
# ================================
MEDIA_CDN_URL=https://cdn.example.com

# ================================
# Email (Resend)
# ================================
ENABLE_EMAIL=false
RESEND_API_KEY=re_your_api_key_here

# ================================
# Redis
# ================================
ENABLE_REDIS=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_DB=0

# ================================
# SEO & Public App Info
# ================================
NEXT_PUBLIC_COMPANY_NAME="Your Company Name"
NEXT_PUBLIC_SITE_URL="https://yoursite.com"
NEXT_PUBLIC_LOGO_URL="/favicon.png"
NEXT_PUBLIC_PHONE_NUMBER="+1-000-000-0000"
NEXT_PUBLIC_SOCIAL_X="https://x.com/yourhandle"
NEXT_PUBLIC_SOCIAL_FACEBOOK="https://facebook.com/yourpage"